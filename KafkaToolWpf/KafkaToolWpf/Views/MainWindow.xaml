<Window x:Class="KafkaToolWpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/" 
        xmlns:viewmodels="clr-namespace:KafkaToolWpf.ViewModels"
        xmlns:converters="clr-namespace:KafkaToolWpf.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        prism:ViewModelLocator.AutoWireViewModel="True"
        x:Name="mainWindow"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        Title="KafkaTool - Kafka 管理工具" Height="800" Width="1000" MinHeight="600" MinWidth="900">
    <Window.Resources>
        <converters:BoolToInverseConverter x:Key="BoolToInverse"/>
        <converters:LongToLagColorConverter x:Key="LongToLagColor"/>
        <converters:BoolToLoadingTextConverter x:Key="BoolToLoadingText"/>
        <converters:BoolToConsumingTextConverter x:Key="BoolToConsumingText"/>
        <converters:StringNotEmptyToVisibleConverter x:Key="StringNotEmptyToVisible"/>
    </Window.Resources>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closing" SourceObject="{Binding ElementName=mainWindow}">
            <i:InvokeCommandAction Command="{Binding WindowClosingCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Connection bar -->
            <RowDefinition Height="40"/>
            <!-- Tab content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========== Top Connection Bar ========== -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="0 0 0 1">
            <Grid Margin="8 4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Kafka地址：" FontSize="14" VerticalAlignment="Center" Margin="0 0 5 0"/>
                <TextBox Grid.Column="1" Text="{Binding KafkaBootstrapServer}" FontSize="14" Height="26" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Command="{Binding TestConnectionCommand}" Content="测试连接" FontSize="13" Height="26" Width="80" Margin="5 0"/>
                <Button Grid.Column="3" Command="{Binding ManageConnectionsCommand}" Content="连接管理" FontSize="13" Height="26" Width="80" Margin="5 0 0 0"/>
            </Grid>
        </Border>

        <!-- ========== Main Content with Tabs ========== -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" Margin="0">
            <!-- ==================== Tab 0: 生产/消费 ==================== -->
            <TabItem Header="生产/消费">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Producer Topic -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 5">
                        <TextBlock Width="120" FontSize="14" VerticalAlignment="Center">生产者Topic：</TextBlock>
                        <TextBox Text="{Binding ProducerTopic}" Width="250" FontSize="14" Height="26"/>
                        <TextBlock Width="80" FontSize="14" VerticalAlignment="Center" Margin="20 0 0 0">指定分区：</TextBlock>
                        <TextBox Text="{Binding ProducerPartition, TargetNullValue=''}" Width="80" FontSize="14" Height="26"/>
                        <TextBlock Width="60" FontSize="14" VerticalAlignment="Center" Margin="20 0 0 0">消息Key：</TextBlock>
                        <TextBox Text="{Binding ProducerKey}" Width="200" FontSize="14" Height="26"/>
                    </StackPanel>

                    <!-- Producer Message -->
                    <DockPanel Grid.Row="1" Margin="0 5" Height="100">
                        <DockPanel DockPanel.Dock="Top">
                            <TextBlock FontSize="14" VerticalAlignment="Center">消息内容：</TextBlock>
                            <TextBlock FontSize="14" VerticalAlignment="Center" Margin="10 0 0 0">Headers：</TextBlock>
                            <TextBox Text="{Binding ProducerHeaders}" FontSize="12" Height="22" VerticalAlignment="Center" 
                                     ToolTip="每行一个，格式: key=value"/>
                        </DockPanel>
                        <TextBox Text="{Binding ProducerMessage}" FontSize="14" AcceptsReturn="True" TextWrapping="Wrap" Margin="0 2 0 0"/>
                    </DockPanel>

                    <!-- Producer Buttons -->
                    <Grid Grid.Row="2" Margin="0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding ProducerStatus}" FontSize="12" VerticalAlignment="Center" 
                                   Foreground="Gray" TextWrapping="NoWrap" TextTrimming="None"
                                   Margin="0 0 10 0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Command="{Binding AcquireTopicListCommand}" Margin="0 0 10 0" FontSize="13" Height="28">获取TopicList</Button>
                            <Button Command="{Binding SendMessageCommand}" FontSize="13" Height="28" Width="90">发送消息</Button>
                        </StackPanel>
                    </Grid>

                    <Separator Grid.Row="3" Margin="0 5" VerticalAlignment="Top"/>

                    <!-- Consumer -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0 5">
                        <TextBlock Width="120" FontSize="14" VerticalAlignment="Center">消费者Topic：</TextBlock>
                        <TextBox Text="{Binding ConsumerTopic}" IsReadOnly="{Binding IsConsumerReadonly}" FontSize="14" Height="26" Width="250"/>
                        <TextBlock Width="80" FontSize="14" VerticalAlignment="Center" Margin="20 0 0 0">Group：</TextBlock>
                        <TextBox Text="{Binding ConsumerGroup}" IsReadOnly="{Binding IsConsumerReadonly}" FontSize="14" Height="26" Width="250"/>
                    </StackPanel>

                    <!-- Consumer Message -->
                    <TextBox Grid.Row="5" x:Name="txtConsumerMessage" Text="{Binding ConsumerMessage}" 
                             VerticalScrollBarVisibility="Auto" FontSize="13" IsReadOnly="True"
                             AcceptsReturn="True" TextWrapping="Wrap" Margin="0 5"/>

                    <!-- Consumer Controls -->
                    <Grid Grid.Row="6" Margin="0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding ConsumerTooltipMsg}" Foreground="Red" FontSize="13" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="状态: " FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding IsConsuming, Converter={StaticResource BoolToConsumingText}}" FontSize="12" VerticalAlignment="Center" Margin="0 0 10 0"/>
                            <Button Command="{Binding SubscribeMessageCommand}" CommandParameter="{Binding ElementName=txtConsumerMessage}" 
                                    FontSize="13" Height="28" Margin="0 0 10 0" Content="订阅消息"/>
                            <Button Command="{Binding CancelSubscribeCommand}" FontSize="13" Height="28" Content="取消订阅"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="7" Text="{Binding ConnectionStatus}" FontSize="11" Foreground="Gray"/>

                    <!-- Consumer Error -->
                    <Border Grid.Row="8" Background="#FFF0F0" BorderBrush="#FFCCCC" BorderThickness="1"
                            Visibility="{Binding ConsumerErrorMessage, Converter={StaticResource StringNotEmptyToVisible}}">
                        <TextBlock Text="{Binding ConsumerErrorMessage}" FontSize="12" Foreground="#CC0000"
                                   Margin="5 3" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ==================== Tab 1: Topic 管理 ==================== -->
            <TabItem Header="Topic 管理">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Topic list -->
                    <Grid Grid.Column="0" Margin="0 0 8 0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="Topic 列表" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="{Binding IsTopicLoading, Converter={StaticResource BoolToLoadingText}}" FontSize="12" Foreground="Gray" VerticalAlignment="Center" Margin="8 0 0 0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 5">
                            <TextBox Text="{Binding TopicFilter}" FontSize="13" Height="24" Width="200" ToolTip="搜索过滤"/>
                            <Button Command="{Binding RefreshTopicListCommand}" FontSize="12" Height="24" Width="70" Margin="5 0 0 0" Content="刷新"/>
                        </StackPanel>

                        <ListBox Grid.Row="2" ItemsSource="{Binding FilteredTopicList}" SelectedItem="{Binding SelectedTopic}" 
                                 DisplayMemberPath="TopicName" Height="200" Margin="0 5"/>

                        <!-- Topic actions -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0 5">
                            <Button Command="{Binding CreateTopicCommand}" Content="创建Topic" FontSize="13" Height="28" Width="90" Margin="0 0 5 0"/>
                            <Button Command="{Binding DeleteTopicCommand}" Content="删除Topic" FontSize="13" Height="28" Width="90" Margin="0 0 5 0"/>
                            <Button Command="{Binding ViewTopicDetailCommand}" Content="查看详情" FontSize="13" Height="28" Width="90"/>
                        </StackPanel>

                        <TextBlock Grid.Row="4" Text="{Binding TopicStatus}" FontSize="12" Foreground="Gray"/>
                    </Grid>

                    <!-- Right: Topic detail -->
                    <Grid Grid.Column="1" Margin="8 0 0 0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Topic 详情 (在 Topic 列表中选择后点击查看详情)" FontSize="13" Foreground="Gray"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Grid x:Name="TopicDetailPanel">
                                <!-- Details shown in MessageBox for now -->
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ==================== Tab 2: 消费者组 ==================== -->
            <TabItem Header="消费者组">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Consumer group list -->
                    <Grid Grid.Column="0" Margin="0 0 8 0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="消费者组列表" FontSize="16" FontWeight="Bold"/>
                            <Button Command="{Binding RefreshConsumerGroupsCommand}" FontSize="12" Height="24" Width="70" Margin="10 0" Content="刷新"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding ConsumerGroups}" AutoGenerateColumns="False"
                                  SelectedItem="{Binding SelectedConsumerGroup}" IsReadOnly="True" RowHeight="26" Height="150" Margin="0 5">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Group ID" Width="*" Binding="{Binding GroupId}"/>
                                <DataGridTextColumn Header="状态" Width="80" Binding="{Binding State}"/>
                                <DataGridTextColumn Header="成员" Width="60" Binding="{Binding MemberCount}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0 5">
                            <Button Command="{Binding ViewConsumerGroupDetailCommand}" Content="查看详情(Lag)" FontSize="13" Height="28" Margin="0 0 0 5"/>
                            <Button Command="{Binding DeleteConsumerGroupCommand}" Content="删除消费者组" FontSize="13" Height="28" Margin="0 0 0 5"/>
                            <Button Command="{Binding ResetConsumerGroupOffsetCommand}" Content="重置偏移量(OFFSET=0)" FontSize="13" Height="28"/>
                        </StackPanel>

                        <TextBlock Grid.Row="3" Text="{Binding ConsumerGroupStatus}" FontSize="12" Foreground="Gray"/>
                        <TextBlock Grid.Row="4" Text="{Binding TotalLag, StringFormat='总 Lag: {0}'}" FontSize="14" FontWeight="Bold" 
                                   Foreground="{Binding TotalLag, Converter={StaticResource LongToLagColor}}" Margin="0 5"/>
                    </Grid>

                    <!-- Right: Consumer group detail (lag per partition) -->
                    <Grid Grid.Column="1" Margin="8 0 0 0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="分区 Lag 详情" FontSize="14" FontWeight="Bold" Margin="0 0 0 5"/>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding ConsumerGroupDetails}" AutoGenerateColumns="False"
                                  IsReadOnly="True" RowHeight="26">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Topic" Width="*" Binding="{Binding Topic}"/>
                                <DataGridTextColumn Header="分区" Width="60" Binding="{Binding Partition}"/>
                                <DataGridTextColumn Header="当前偏移" Width="90" Binding="{Binding CurrentOffset}"/>
                                <DataGridTextColumn Header="LOG-END" Width="90" Binding="{Binding LogEndOffset}"/>
                                <DataGridTextColumn Header="Lag" Width="80" Binding="{Binding Lag}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style>
                                            <Setter Property="TextBlock.Foreground" 
                                                    Value="{Binding Lag, Converter={StaticResource LongToLagColor}}"/>
                                            <Setter Property="TextBlock.FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ==================== Tab 3: 消息浏览 ==================== -->
            <TabItem Header="消息浏览">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 5">
                        <TextBlock Text="Topic：" FontSize="14" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding BrowseTopic}" Width="250" FontSize="14" Height="26" Margin="5 0"/>
                        <TextBlock Text="分区（可选）：" FontSize="14" VerticalAlignment="Center" Margin="20 0 0 0"/>
                        <TextBox Text="{Binding BrowsePartition, TargetNullValue=''}" Width="80" FontSize="14" Height="26" Margin="5 0"/>
                        <TextBlock Text="起始偏移（可选）：" FontSize="14" VerticalAlignment="Center" Margin="20 0 0 0"/>
                        <TextBox Text="{Binding BrowseOffset, TargetNullValue=''}" Width="100" FontSize="14" Height="26" Margin="5 0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 5">
                        <TextBlock Text="条数：" FontSize="14" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding BrowseCount}" Width="80" FontSize="14" Height="26" Margin="5 0"/>
                        <CheckBox IsChecked="{Binding BrowseByTimestamp}" Content="按时间浏览" FontSize="13" Margin="20 0 0 0" VerticalAlignment="Center"/>
                        <DatePicker SelectedDate="{Binding BrowseTimestamp}" FontSize="13" Height="26" Margin="10 0 0 0"/>
                        <TextBlock Text="{Binding BrowseTimestamp, StringFormat=' HH:mm:ss'}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0 10">
                        <Button Command="{Binding BrowseMessagesCommand}" Content="浏览消息" FontSize="14" Height="30" Width="100"/>
                        <TextBlock FontSize="12" Foreground="Gray" VerticalAlignment="Center" Margin="10 0 0 0">
                            将打开新窗口显示消息列表（分区、偏移量、时间戳、Key、Value、Headers）
                        </TextBlock>
                    </StackPanel>

                    <Separator Grid.Row="3" Margin="0 10"/>

                    <StackPanel Grid.Row="4" Margin="0 10">
                        <TextBlock Text="使用说明" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text="• 按偏移浏览：指定 Topic + 分区 + 偏移量，从指定位置读取N条消息" FontSize="12" Margin="0 5"/>
                        <TextBlock Text="• 按时间浏览：指定 Topic + 时间，从该时间点开始读取N条消息" FontSize="12" Margin="0 2"/>
                        <TextBlock Text="• 不指定分区则轮询所有分区" FontSize="12" Margin="0 2"/>
                        <TextBlock Text="• 消息详情包含：分区、偏移量、时间戳、Key、Value、Headers" FontSize="12" Margin="0 2"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ==================== Tab 4: 集群信息 ==================== -->
            <TabItem Header="集群信息">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 5">
                        <TextBlock Text="集群信息" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Command="{Binding RefreshClusterInfoCommand}" Content="刷新" FontSize="12" Height="24" Width="70" Margin="10 0"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="{Binding ClusterStatus}" FontSize="13" Foreground="Gray" Margin="0 5"/>

                    <!-- Cluster details -->
                    <Border Grid.Row="2" BorderBrush="#EEE" BorderThickness="1" Margin="0 10" Padding="15" Background="#FAFAFA">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Cluster ID：" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ClusterInfo.ClusterId}" FontSize="14"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Controller ID：" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ClusterInfo.ControllerId}" FontSize="14"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Broker 数量：" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ClusterInfo.BrokerCount}" FontSize="14"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Topic 数量：" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ClusterInfo.TopicCount}" FontSize="14"/>
                        </Grid>
                    </Border>

                    <!-- Broker list -->
                    <GroupBox Grid.Row="3" Header="Broker 列表" Margin="0 10">
                        <ItemsControl ItemsSource="{Binding ClusterInfo.Brokers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EEE" BorderThickness="0 0 0 1" Padding="5">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding BrokerId, StringFormat='ID: {0}'}" FontSize="13" FontWeight="Bold" Width="80"/>
                                            <TextBlock Text="{Binding Endpoint, StringFormat='地址: {0}'}" FontSize="13" Width="200"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>