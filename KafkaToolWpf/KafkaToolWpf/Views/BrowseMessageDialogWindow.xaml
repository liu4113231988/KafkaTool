<UserControl x:Class="KafkaToolWpf.Views.BrowseMessageDialogWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             Width="900" Height="550">
    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">
            <Setter Property="prism:Dialog.WindowStartupLocation" Value="CenterScreen" />
            <Setter Property="ShowInTaskbar" Value="False"/>
            <Setter Property="Title" Value="浏览消息"/>
        </Style>
    </prism:Dialog.WindowStyle>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding TopicName, StringFormat='Topic: {0}'}" 
                   FontSize="16" FontWeight="Bold" Margin="0 0 0 10"/>

        <DockPanel Grid.Row="1" Margin="0 0 0 10">
            <TextBlock Text="筛选：" VerticalAlignment="Center" FontSize="13"/>
            <TextBox Text="{Binding FilterText}" Width="280" Height="26" Margin="8 0 0 0"
                     ToolTip="按 Topic、Key、Value、Headers 搜索"/>
        </DockPanel>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Messages}" SelectedItem="{Binding SelectedMessage}" AutoGenerateColumns="False"
                  FontSize="13" IsReadOnly="True" RowHeight="28"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="分区" Width="60" Binding="{Binding Partition}"/>
                <DataGridTextColumn Header="偏移量" Width="80" Binding="{Binding Offset}"/>
                <DataGridTextColumn Header="时间戳" Width="150" Binding="{Binding FormattedTimestamp}"/>
                <DataGridTextColumn Header="Key" Width="120" Binding="{Binding Key}"/>
                <DataGridTextColumn Header="Value" Width="*" Binding="{Binding Value}"/>
                <DataGridTextColumn Header="Headers" Width="220" Binding="{Binding FormattedHeaders}"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 10 0 0">
            <Button Command="{Binding ExportCommand}" Content="导出" FontSize="14" Width="80" Height="30" Margin="0 0 10 0"/>
            <Button Command="{Binding CopyToProducerCommand}" Content="复制到生产区" FontSize="14" Width="110" Height="30" Margin="0 0 10 0"/>
            <Button Command="{Binding CloseCommand}" Content="关闭" FontSize="14" Width="80" Height="30"/>
        </StackPanel>
    </Grid>
</UserControl>
